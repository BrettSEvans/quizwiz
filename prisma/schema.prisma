generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Quizmaster {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  name              String
  invitedBy         String?  // FK to another Quizmaster (invite-only signup)

  packages          Package[]
  hosts             Host[]   @relation("QuizmasterHosts") // Hosts managed by this Quizmaster
  invites           QuizmasterInvite[]
  sentInvites       QuizmasterInvite[] @relation("InvitedBy")
  archives          GameArchive[]
  retentionPolicy   RetentionPolicy?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime? // Soft delete
}

model QuizmasterInvite {
  id                String   @id @default(cuid())
  quizmasterId      String
  quizmaster        Quizmaster @relation(fields: [quizmasterId], references: [id], onDelete: Cascade)
  invitedBy         String?
  sentBy            Quizmaster? @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull)

  inviteCode        String   @unique
  inviteEmail       String?  // For email-based invites
  inviteType        String   @default("email") // email, manual_code

  expiresAt         DateTime
  acceptedAt        DateTime?
  acceptedBy        String?  // FK to Host once accepted

  createdAt         DateTime @default(now())
}

model Host {
  id                String   @id @default(cuid())
  quizmasterId      String
  quizmaster        Quizmaster @relation("QuizmasterHosts", fields: [quizmasterId], references: [id], onDelete: Cascade)

  email             String
  name              String
  passwordHash      String
  inviteCode        String? // Last invite code used

  status            String   @default("active") // active, disabled, soft_removed
  notes             String   @default("") // Append-only audit trail
  contactInfo       Json? // { phone?, address?, notes? }

  lastGameDate      DateTime?
  disabledAt        DateTime?
  enabledAt         DateTime?
  deletedAt         DateTime? // Soft delete

  games             Game[]   // Games hosted by this Host

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([quizmasterId, email])
}

model RetentionPolicy {
  id                String   @id @default(cuid())
  quizmasterId      String   @unique
  quizmaster        Quizmaster @relation(fields: [quizmasterId], references: [id], onDelete: Cascade)

  daysToRetain      Int      @default(365)
  autoDeleteArchivesOlderThan DateTime?

  updatedAt         DateTime @updatedAt
}

model GameArchive {
  id                String   @id @default(cuid())
  gameId            String?  // May not have original game if deleted
  quizmasterId      String
  quizmaster        Quizmaster @relation(fields: [quizmasterId], references: [id], onDelete: Cascade)

  venueName         String
  hostName          String
  gameDate          DateTime

  snapshot          Json     // { scores, answers, questions, teams, duration, ... }

  archivedAt        DateTime @default(now())
  deletedAt         DateTime? // Soft delete
  createdAt         DateTime @default(now())
}

model Package {
  id                String   @id @default(cuid())
  quizmasterId      String
  quizmaster        Quizmaster @relation(fields: [quizmasterId], references: [id], onDelete: Cascade)

  name              String
  status            String   @default("draft") // draft, published
  data              Json     // Serialized DraftPackage
  versions          PackageVersion[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PackageVersion {
  id                String   @id @default(cuid())
  packageId         String
  package           Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  versionNumber     Int
  snapshot          Json     // Serialized FrozenPackage
  publishedAt       DateTime

  createdAt         DateTime @default(now())

  @@unique([packageId, versionNumber])
}

model Game {
  id                String   @id @default(cuid())
  hostId            String?
  host              Host?    @relation(fields: [hostId], references: [id], onDelete: SetNull)

  hostName          String   // Denormalized for archival
  venueName         String
  sessionToken      String   @unique
  boardToken        String   @unique
  qrCode            String?
  manualJoinCode    String   @unique

  // Package snapshot frozen at game start
  packageSnapshot   Json

  // Game state
  status            String   @default("registration") // registration, active, locked, completed
  currentRoundIndex Int      @default(0)

  teams             Team[]
  rounds            Round[]
  scores            Score[]

  archivedAt        DateTime? // When game was moved to archive

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Team {
  id                String   @id @default(cuid())
  gameId            String
  game              Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  name              String
  teamToken         String   @unique
  status            String   @default("active") // active, soft_removed

  answers           Answer[]
  scores            Score[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([gameId, name])
}

model Round {
  id                String   @id @default(cuid())
  gameId            String
  game              Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  index             Int
  name              String
  status            String   @default("active") // active, locked, published
  roundType         String   @default("standard") // standard, optional, custom

  questions         Question[]
  answers           Answer[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([gameId, index])
}

model Question {
  id                String   @id @default(cuid())
  roundId           String
  round             Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)

  index             Int
  text              String
  type              String   @default("standard") // standard, musical, bonus, custom

  // Musical question fields
  musicalArtistLabel String?
  musicalYearLabel   String?

  answers           Answer[]
  scores            Score[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([roundId, index])
}

model Answer {
  id                String   @id @default(cuid())
  teamId            String
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  roundId           String
  round             Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  questionId        String
  question          Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Answer content
  text              String
  musicalArtist     String?
  musicalYear       String?

  // Draft tracking
  isDraft           Boolean  @default(false)
  submittedAt       DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([teamId, roundId, questionId])
}

model Score {
  id                String   @id @default(cuid())
  gameId            String
  game              Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teamId            String
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  questionId        String
  question          Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  points            Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([gameId, teamId, questionId])
}

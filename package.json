{
  "name": "quizwiz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --import tsx server.ts",
    "dev:daemon": "npm run dev > logs.txt 2>&1 &",
    "build": "next build",
    "start": "node --import tsx server.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "setup": "npm install && npx prisma migrate dev --name init && npx prisma generate",
    "db:reset": "npx prisma migrate reset --force",
    "lint": "eslint"
  },
  "dependencies": {
    "@playwright/test": "^1.61.0",
    "@prisma/client": "^7.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "bcrypt": "^6.0.0",
    "jose": "^6.2.3",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vitest": "^4.1.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
